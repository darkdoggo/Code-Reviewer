{
  "name": "code-reviewer",
  "productName": "Code Reviewer",
  "version": "1.0.0",
  "description": "Code Reviewer - A desktop app for full-stack code review",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "pack:mac": "npm run build && electron-builder --mac --arm64 --x64",
    "pack:mac-arm64": "npm run build && electron-builder --mac --arm64",
    "pack:mac-x64": "npm run build && electron-builder --mac --x64",
    "pack:win": "npm run build && electron-builder --win --x64",
    "pack:all": "npm run build && electron-builder --mac --win --arm64 --x64",
    "pack:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.62.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "better-sqlite3": "^11.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "electron-store": "^10.0.0",
    "i18next": "^26.0.6",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.0",
    "openai": "^6.34.0",
    "react-i18next": "^17.0.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.27.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "ts-morph": "^28.0.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
